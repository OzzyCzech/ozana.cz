---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Avatar from "../components/Avatar.astro";
import GitHubIcon from '../icons/github.svg';
import TypingHeadline from "../components/TypingHeadline.astro";
---

<Layout
	title="Ing. Roman Ožana a Full-Stack Developer"
	description="Hey, I'm Roman Ožana, a passionate Full-Stack Developer specializing in building robust web applications and services. Explore my projects and get in touch!">

	<Header/>

	<main id="main" class="container mx-auto p-4 self-center align-center" itemscope itemtype="https://schema.org/Person">

		<div class="flex flex-wrap justify-center my-10">
			<Avatar/>
		</div>

		<article class="text-center">

			<h1 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900 mb-1.5">
				Hey, I'm Roman.
			</h1>

			<TypingHeadline/>

			<div class="my-5">
				<a href="https://github.com/OzzyCzech/" target="_blank" rel="noopener" class="btn">
					<GitHubIcon class="size-5"/>
					View GitHub
				</a>
			</div>
		</article>

	</main>

	<Footer/>
</Layout>
