---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Zdrojak from "../components/work/zdrojak/Zdrojak.astro";
import Testomato from "../components/work/testomato/Testomato.astro";
import GitHub from "../components/work/github/GitHub.astro";
import Articles from "../components/work/Articles.astro";
---

<Layout title="Ing. Roman Ožana / Projects">
	<Header/>
	<main id="main" class="container px-4 mx-auto max-w-screen-lg">

		<div class="py-10 md:py-16 lg:py-20 text-center">
			<p class="kicker mb-4"><span class="text-ink-500">~ $</span> ls ./projects</p>
			<h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-ink-50">Projects<span class="text-amber-glow">.</span></h1>
			<p class="mt-3 text-ink-300 text-lg">Things I've built and contribute to.</p>
		</div>

		<div class="space-y-12">
			<Testomato/>
			<Zdrojak/>
		</div>

		<GitHub/>

		<Articles/>

	</main>
	<Footer/>
</Layout>
