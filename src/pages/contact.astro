---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Mail, MapPin, Phone, Bookmark } from '@lucide/astro';
---
<Layout title="Ing. Roman Ožana / Contact">

	<Header/>

	<main id="main" class="max-w-xl mx-auto px-4 py-12 md:py-24 flex flex-col items-center justify-center">

		<div class="mb-10 text-center">
			<p class="kicker mb-4"><span class="text-ink-500">~ $</span> open ./contact</p>
			<h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-ink-50 mb-3">
				Let's get in touch<span class="text-amber-glow">.</span>
			</h1>
			<p class="text-ink-300 text-lg">Feel free to reach out anytime.</p>
		</div>

		<div class="flex flex-col gap-6 w-full">
			<a href="mailto:roman@ozana.cz" itemprop="email" class="flex items-center gap-4 p-4 border border-ink-800 hover:border-ink-500 hover:bg-ink-900 hover:no-underline transition-colors group">
				<div class="text-amber-glow">
					<Mail class="size-5"/>
				</div>
				<div>
					<p class="font-mono text-xs uppercase tracking-widest text-ink-500">Email</p>
					<p class="font-semibold text-ink-50">roman@ozana.cz</p>
				</div>
			</a>

			<a href="tel:+420605783455" itemprop="telephone" class="flex items-center gap-4 p-4 border border-ink-800 hover:border-ink-500 hover:bg-ink-900 hover:no-underline transition-colors group">
				<div class="text-amber-glow">
					<Phone class="size-5"/>
				</div>
				<div>
					<p class="font-mono text-xs uppercase tracking-widest text-ink-500">Phone</p>
					<p class="font-semibold text-ink-50">+420 605 783 455</p>
				</div>
			</a>

			<div class="flex items-center gap-4 p-4 border border-ink-800" itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
				<div class="text-amber-glow">
					<MapPin class="size-5"/>
				</div>
				<div>
					<p class="font-mono text-xs uppercase tracking-widest text-ink-500">Location</p>
					<p class="font-semibold text-ink-50">
						<span hidden itemprop="streetAddress">Přímětická 1199/36</span>
						<span itemprop="addressLocality">Prague</span>,
						<span itemprop="addressRegion">Czech Republic</span>
						<span hidden itemprop="postalCode">14000</span>
					</p>
				</div>
			</div>
		</div>

		<div class="mt-8 text-center">
			<a
				href="/ozana.vcf"
				class="btn"
				download="Roman Ožana.vcf">
				<Bookmark class="size-4"/>
				Add to Contacts
			</a>
		</div>

		<p class="mt-6 font-mono text-sm text-ink-500 text-center">
			IN:&nbsp;<a href="https://www.rzp.cz/verejne-udaje/cs/udaje/vyber-subjektu;ico=87098504" title="Registration number" target="_blank" rel="noopener" class="text-ink-500 hover:text-amber-glow">87098504</a>
		</p>

	</main>
	<Footer/>
</Layout>
