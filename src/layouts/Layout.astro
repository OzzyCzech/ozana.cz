---
import '../styles/global.css';

export interface Props {
	title: string;
	description?: string;
}

const {
	title = "Ing. Roman Ožana",
	description = "Personal website of Roman Ožana",
} = Astro.props;

import SpeedInsights from "@vercel/speed-insights/astro"

const canonical = new URL(Astro.url.pathname, "https://ozana.cz");
---

<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8"/>
	<meta name="viewport" content="width=device-width"/>
	<link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
	<link rel="canonical" href={canonical}/>
	<link rel="author" href="/humans.txt"/>
	<title>{title}</title>
	<meta name="description" content={description}/>
	<meta name="author" content="All: Roman Ožana; e-mail: roman@ozana.cz"/>
	<link rel="sitemap" href="/sitemap-index.xml"/>
	<script is:inline type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "Person",
		"name": "Roman Ožana",
		"honorificPrefix": "Ing.",
		"url": "https://ozana.cz",
		"sameAs": [
			"https://github.com/OzzyCzech",
			"https://stackoverflow.com/users/355316/ozzyczech",
			"https://www.linkedin.com/in/roman-ozana",
			"https://ozzyczech.cz"
		],
		"jobTitle": "Full-Stack Developer",
		"email": "roman@ozana.cz"
	})}/>
</head>
<body class="font-sans bg-white print:bg-transparent text-slate-900 antialiased leading-normal tracking-normal grid min-h-screen grid-rows-[auto_1fr_auto]">
<a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-slate-800 focus:text-white focus:rounded-md focus:text-sm focus:font-medium">Skip to content</a>
<slot/>
<SpeedInsights/>
</body>
</html>