---
const currentPath = Astro.url.pathname;
import { Menu, X, Github } from '@lucide/astro';
---

<header class="w-full sm:border-b sm:border-dashed sm:border-slate-300 print:hidden">
<div class="px-4 sm:px-6 w-full max-w-3xl lg:max-w-7xl mx-auto relative">
	<nav class="flex items-center justify-between h-14">
		<a href="/" class="flex items-center gap-2.5 hover:no-underline">
			<div class="flex items-center justify-center size-7 rounded-md overflow-hidden shrink-0 bg-slate-800 text-white text-xs font-bold">
				RO
			</div>
			<span class="text-sm font-semibold text-slate-900">Roman Ožana</span>
		</a>

		<div class="hidden lg:flex items-center gap-1">
			<a href="/" class="nav-link" class:list={[currentPath === '/' && 'active']}>Home</a>
			<a href="/projects" class="nav-link" class:list={[currentPath.startsWith('/projects') && 'active']}>Projects</a>
			<a href="/resume" class="nav-link" class:list={[currentPath.startsWith('/resume') && 'active']}>Resume</a>
			<a href="/contact" class="nav-link" class:list={[currentPath.startsWith('/contact') && 'active']}>Contact</a>
			<a href="https://github.com/OzzyCzech/" target="_blank" class="nav-icon" aria-label="GitHub">
				<Github class="size-4"/>
			</a>
		</div>

		<button
			class="p-2 rounded-md hover:bg-slate-100 lg:hidden"
			aria-label="Toggle menu"
			id="menu-toggle"
		>
			<Menu class="size-5" id="icon-menu"/>
			<X class="size-5 hidden" id="icon-close"/>
		</button>
	</nav>

	<div id="mobile-menu" class="hidden lg:hidden absolute left-0 right-0 sm:left-auto sm:right-0 sm:w-48 top-full bg-white border border-slate-200 rounded-lg mx-4 sm:mx-0 sm:mr-6 p-2 z-50 shadow-lg">
		<div class="flex flex-col">
			<a href="/" class="mobile-nav-link">Home</a>
			<a href="/projects" class="mobile-nav-link">Projects</a>
			<a href="/resume" class="mobile-nav-link">Resume</a>
			<a href="/contact" class="mobile-nav-link">Contact</a>
			<hr class="my-2 border-slate-200"/>
			<a href="https://github.com/OzzyCzech/" target="_blank" class="mobile-nav-link inline-flex items-center gap-2">
				<Github class="size-4"/> GitHub
			</a>
		</div>
	</div>
</div>
</header>

<style>
	@reference "tailwindcss";

	.nav-link {
		@apply px-3 py-1.5 text-sm font-medium text-slate-500 rounded-md hover:no-underline hover:text-slate-900 hover:bg-slate-100 transition-colors;
	}

	.nav-link.active {
		@apply text-slate-900;
	}

	.nav-icon {
		@apply p-2 text-slate-500 rounded-md hover:no-underline hover:text-slate-900 hover:bg-slate-100 transition-colors ml-1;
	}

	.mobile-nav-link {
		@apply px-3 py-2 text-sm font-medium text-slate-600 rounded-md hover:no-underline hover:text-slate-900 hover:bg-slate-50 transition-colors;
	}
</style>

<script>
	const toggle = document.getElementById('menu-toggle');
	const mobileMenu = document.getElementById('mobile-menu');
	const iconMenu = document.getElementById('icon-menu');
	const iconClose = document.getElementById('icon-close');

	toggle?.addEventListener('click', () => {
		mobileMenu?.classList.toggle('hidden');
		iconMenu?.classList.toggle('hidden');
		iconClose?.classList.toggle('hidden');
	});

	document.addEventListener('click', (e) => {
		if (!toggle?.contains(e.target as Node) && !mobileMenu?.contains(e.target as Node)) {
			mobileMenu?.classList.add('hidden');
			iconMenu?.classList.remove('hidden');
			iconClose?.classList.add('hidden');
		}
	});
</script>
