---
import {
	Apple,
	Linux,
	Ava,
	Css,
	Cypress,
	Git,
	GnuMake,
	Html,
	Js,
	TypeScript,
	Symfony,
	Mocha,
	Mongodb,
	Mariadb,
	Vue,
	Npm,
	Nette,
	NextJs,
	Nodejs,
	Parcel,
	Vite,
	Astro as AstroIcon,
	Php,
	PhpStorm,
	Docker,
	PhpUnit,
	React,
	Redis,
	Svelte,
	Vitest,
	Tailwind,
	Webpack,
	Wordpress,
	ZendFramework
} from "@wticons/astro";
---
<section class="break-before-page">
	<h2 class="section-title mb-6">Tech I Love Working With</h2>

	<div class="grid gap-10 sm:grid-cols-2">

		<article>
			<h3 class="text-sm font-medium text-muted-foreground uppercase tracking-wider mb-3">Backend</h3>
			<div class="flex flex-wrap gap-4 *:flex *:flex-col *:items-center *:gap-1">
				<a href="https://www.php.net" target="_blank" rel="noopener">
					<Php class="size-14"/>
					<small class="text-xs text-slate-500">PHP</small>
				</a>
				<a href="https://nodejs.org" target="_blank" rel="noopener">
					<Nodejs class="size-14"/>
					<small class="text-xs text-slate-500">Node.js</small>
				</a>
				<a href="https://framework.zend.com/" target="_blank" rel="noopener">
					<ZendFramework class="size-14"/>
					<small class="text-xs text-slate-500">Zend</small>
				</a>
				<a href="https://nette.org" target="_blank" rel="noopener">
					<Nette class="size-14"/>
					<small class="text-xs text-slate-500">Nette</small>
				</a>
				<a href="https://symfony.com" target="_blank" rel="noopener">
					<Symfony class="size-14"/>
					<small class="text-xs text-slate-500">Symfony</small>
				</a>
			</div>
		</article>

		<article>
			<h3 class="text-sm font-medium text-muted-foreground uppercase tracking-wider mb-3">Frontend</h3>
			<div class="flex flex-wrap gap-4 *:flex *:flex-col *:items-center *:gap-1">
				<a href="https://developer.mozilla.org/en-US/docs/Web/JavaScript" target="_blank" rel="noopener">
					<Js class="size-14"/>
					<small class="text-xs text-slate-500">Javascript</small>
				</a>
				<a href="https://developer.mozilla.org/en-US/docs/Web/JavaScript" target="_blank" rel="noopener">
					<TypeScript class="size-14"/>
					<small class="text-xs text-slate-500">Typescript</small>
				</a>
				<a href="https://developer.mozilla.org/en-US/docs/Web/HTML" target="_blank" rel="noopener">
					<Html class="size-14"/>
					<small class="text-xs text-slate-500">HTML5</small>
				</a>
				<a href="https://developer.mozilla.org/en-US/docs/Web/CSS" target="_blank" rel="noopener">
					<Css class="size-14"/>
					<small class="text-xs text-slate-500">CSS3</small>
				</a>
				<a href="https://tailwindcss.com" target="_blank" rel="noopener">
					<Tailwind class="size-14"/>
					<small class="text-xs text-slate-500">Tailwind</small>
				</a>
			</div>
		</article>

		<article>
			<h3 class="text-sm font-medium text-muted-foreground uppercase tracking-wider mb-3">Frameworks</h3>
			<div class="flex flex-wrap gap-4 *:flex *:flex-col *:items-center *:gap-1">
				<a href="https://vuejs.org" target="_blank" rel="noopener">
					<Vue class="size-14"/>
					<small class="text-xs text-slate-500">Vue.js</small>
				</a>
				<a href="https://astro.build" target="_blank" rel="noopener">
					<AstroIcon class="size-14"/>
					<small class="text-xs text-slate-500">Astro</small>
				</a>
				<a href="https://svelte.dev" target="_blank" rel="noopener">
					<Svelte class="size-14"/>
					<small class="text-xs text-slate-500">Svelte</small>
				</a>
				<a href="https://reactjs.org" target="_blank" rel="noopener">
					<React class="size-14"/>
					<small class="text-xs text-slate-500">React</small>
				</a>
				<a href="https://nextjs.org" target="_blank" rel="noopener">
					<NextJs class="size-14"/>
					<small class="text-xs text-slate-500">Next.js</small>
				</a>
			</div>
		</article>

		<article>
			<h3 class="text-sm font-medium text-muted-foreground uppercase tracking-wider mb-3">Databases</h3>
			<div class="flex flex-wrap gap-4 *:flex *:flex-col *:items-center *:gap-1">
				<a href="https://www.mongodb.com" target="_blank" rel="noopener">
					<Mongodb class="size-14"/>
					<small class="text-xs text-slate-500">MongoDB</small>
				</a>
				<a href="https://mariadb.org" target="_blank" rel="noopener">
					<Mariadb class="size-14"/>
					<small class="text-xs text-slate-500">MariaDB</small>
				</a>
				<a href="https://redis.io" target="_blank" rel="noopener">
					<Redis class="size-14"/>
					<small class="text-xs text-slate-500">Redis</small>
				</a>
			</div>
		</article>

		<article>
			<h3 class="text-sm font-medium text-muted-foreground uppercase tracking-wider mb-3">Build Tools</h3>
			<div class="flex flex-wrap gap-4 *:flex *:flex-col *:items-center *:gap-1">
				<a href="https://vitejs.dev" target="_blank" rel="noopener">
					<Vite class="size-14"/>
					<small class="text-xs text-slate-500">Vite</small>
				</a>
				<a href="https://www.gnu.org/software/make/" target="_blank" rel="noopener">
					<GnuMake class="size-14"/>
					<small class="text-xs text-slate-500">Make</small>
				</a>
				<a href="https://parceljs.org" target="_blank" rel="noopener">
					<Parcel class="size-14"/>
					<small class="text-xs text-slate-500">Parcel</small>
				</a>
				<a href="https://webpack.js.org" target="_blank" rel="noopener">
					<Webpack class="size-14"/>
					<small class="text-xs text-slate-500">Webpack</small>
				</a>
				<a href="https://www.npmjs.com/" target="_blank" rel="noopener">
					<Npm class="size-14"/>
					<small class="text-xs text-slate-500">NPM</small>
				</a>
			</div>
		</article>

		<article>
			<h3 class="text-sm font-medium text-muted-foreground uppercase tracking-wider mb-3">Testing</h3>
			<div class="flex flex-wrap gap-4 *:flex *:flex-col *:items-center *:gap-1">
				<a href="https://vitest.dev/" target="_blank" rel="noopener">
					<Vitest class="size-14"/>
					<small class="text-xs text-slate-500">Vitest</small>
				</a>
				<a href="https://github.com/avajs/ava" target="_blank" rel="noopener">
					<Ava class="size-14"/>
					<small class="text-xs text-slate-500">Ava</small>
				</a>
				<a href="https://phpunit.de" target="_blank" rel="noopener">
					<PhpUnit class="size-14"/>
					<small class="text-xs text-slate-500">PHPUnit</small>
				</a>
				<a href="https://www.cypress.io" target="_blank" rel="noopener">
					<Cypress class="size-14"/>
					<small class="text-xs text-slate-500">Cypress</small>
				</a>
				<a href="https://mochajs.org" target="_blank" rel="noopener">
					<Mocha class="size-14"/>
					<small class="text-xs text-slate-500">Mocha</small>
				</a>
			</div>
		</article>

		<article class="sm:col-span-2">
			<h3 class="text-sm font-medium text-muted-foreground uppercase tracking-wider mb-3">Tools & Platforms</h3>
			<div class="flex flex-wrap gap-4 *:flex *:flex-col *:items-center *:gap-1">
				<a href="https://www.apple.com/macos" target="_blank" rel="noopener">
					<Apple class="size-14"/>
					<small class="text-xs text-slate-500">macOS</small>
				</a>
				<a href="https://www.linux.org" target="_blank" rel="noopener">
					<Linux class="size-14"/>
					<small class="text-xs text-slate-500">Linux</small>
				</a>
				<a href="https://www.docker.com" target="_blank" rel="noopener">
					<Docker class="size-14"/>
					<small class="text-xs text-slate-500">Docker</small>
				</a>
				<a href="https://git-scm.com" target="_blank" rel="noopener">
					<Git class="size-14"/>
					<small class="text-xs text-slate-500">Git</small>
				</a>
				<a href="https://www.jetbrains.com/phpstorm/" target="_blank" rel="noopener">
					<PhpStorm class="size-14"/>
					<small class="text-xs text-slate-500">PhpStorm</small>
				</a>
				<a href="https://www.wordpress.org" target="_blank" rel="noopener">
					<Wordpress class="size-14"/>
					<small class="text-xs text-slate-500">WordPress</small>
				</a>
			</div>
		</article>

	</div>
</section>
