---
import { Image } from 'astro:assets';
import avatar from '../assets/roman-ozana.small.jpg';
import { Download } from '@lucide/astro';
---

<avatar-download class="w-6/12 sm:w-2/12 relative">
	<button title="Download me" aria-label="Download avatar" type="button" aria-haspopup="true" aria-expanded="false">
		<Image src={avatar} alt="Roman Ožana" class="drop-shadow-sm rounded-full max-w-full h-auto align-middle border-none border" width={512} height={512} loading="eager" fetchpriority="high"/>
	</button>

	<div role="menu" aria-label="Download avatar" class="absolute top-full left-1/2 -translate-x-1/2 z-10 w-48 mt-2 bg-white rounded-sm divide-y divide-slate-100 shadow-sm hidden">
		<ul class="py-1 text-sm text-slate-700">
			<li role="none">
				<a role="menuitem" class="flex items-center gap-2 py-2 px-4 hover:bg-slate-100 hover:no-underline" href="/img/roman-ozana.small.jpg" download>
					<Download class="size-5"/>
					Avatar size
				</a>
			</li>
			<li role="none">
				<a role="menuitem" class="flex items-center gap-2 py-2 px-4 hover:bg-slate-100 hover:no-underline" href="/img/roman-ozana.medium.jpg" download>
					<Download class="size-5"/>
					Medium size
				</a>
			</li>
			<li role="none">
				<a role="menuitem" class="flex items-center gap-2 py-2 px-4 hover:bg-slate-100 hover:no-underline" href="/img/roman-ozana.jpg" download>
					<Download class="size-5"/>
					Original size
				</a>
			</li>
		</ul>
	</div>
</avatar-download>

<script>

	class AvatarDownload extends HTMLElement {
		constructor() {
			super();

			const button = this.querySelector('button');
			const menu = this.querySelector('div');

			const open = () => {
				menu.classList.remove('hidden');
				button.setAttribute('aria-expanded', 'true');
			};

			const close = () => {
				menu.classList.add('hidden');
				button.setAttribute('aria-expanded', 'false');
			};

			button.addEventListener('click', (event) => {
				const isOpen = !menu.classList.contains('hidden');
				isOpen ? close() : open();
				event.stopPropagation();
			});

			button.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') close();
			});

			menu.addEventListener('click', (event) => {
				close();
				event.stopPropagation();
			});

			menu.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') {
					close();
					button.focus();
				}
			});

			document.addEventListener('click', () => close());
		}
	}

	customElements.define('avatar-download', AvatarDownload);

</script>