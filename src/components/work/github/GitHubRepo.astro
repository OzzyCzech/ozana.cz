---
import { fetchRepo } from '../../../lib/github';
import type { GitHubRepo as GitHubRepoType } from '../../../lib/github';

export interface Props {
	url: string;
}

// GitHub linguist language colors
const LANGUAGE_COLORS: Record<string, string> = {
	'JavaScript': '#f1e05a',
	'TypeScript': '#3178c6',
	'PHP':        '#4F5D95',
	'Python':     '#3572A5',
	'HTML':       '#e34c26',
	'CSS':        '#563d7c',
	'Shell':      '#89e051',
	'Makefile':   '#427819',
	'Go':         '#00ADD8',
	'Rust':       '#dea584',
	'Ruby':       '#701516',
	'Java':       '#b07219',
	'C':          '#555555',
	'C++':        '#f34b7d',
	'Swift':      '#F05138',
	'Kotlin':     '#A97BFF',
	'Vue':        '#41b883',
	'Svelte':     '#ff3e00',
	'Astro':      '#ff5a03',
};

const {url} = Astro.props as Props;
const repository = new URL(url).pathname.replace(/^\/|\/$/g, '');
const [owner, repo] = repository.split('/');

const data = (await fetchRepo(repository)) as GitHubRepoType;

const description = data.description || '';
const stars = data.stargazers_count || 0;
const forks = data.forks_count || 0;
const avatarUrl = data.owner?.avatar_url;

const language = data.language || '';
const languagesRaw = (data.languages && typeof data.languages === 'object') ? data.languages : null;
const languagesEntries = languagesRaw ? Object.entries(languagesRaw).filter(([, v]) => typeof v === 'number' && v > 0) : [];
const totalBytes = languagesEntries.reduce((sum, [, v]) => sum + v, 0);

type LangSeg = { name: string; pct: number; color: string; bytes: number };
let langSegments: LangSeg[] = [];

if (totalBytes > 0) {
	langSegments = languagesEntries
		.sort((a, b) => b[1] - a[1])
		.map(([name, bytes]) => ({
			name,
			bytes,
			pct: (bytes / totalBytes) * 100,
			color: LANGUAGE_COLORS[name] || '#94a3b8',
		}));

	const MAX_SEGMENTS = 4;
	if (langSegments.length > MAX_SEGMENTS) {
		const head = langSegments.slice(0, MAX_SEGMENTS);
		const tail = langSegments.slice(MAX_SEGMENTS);
		const otherBytes = tail.reduce((s, x) => s + x.bytes, 0);
		const otherPct = tail.reduce((s, x) => s + x.pct, 0);
		langSegments = [
			...head,
			{ name: 'Other', bytes: otherBytes, pct: otherPct, color: '#94a3b8' },
		];
	}
} else if (language) {
	langSegments = [{ name: language, bytes: 1, pct: 100, color: LANGUAGE_COLORS[language] || '#94a3b8' }];
}
---

<a
	href={url}
	target="_blank"
	rel="noopener"
	class="block overflow-hidden rounded-xl bg-white border border-slate-200 transition-shadow hover:shadow-md focus-visible:outline focus-visible:outline-offset-2 focus-visible:outline-primary p-4 hover:no-underline"
	aria-label={`${owner}/${repo}`}
>
	<header class="flex items-center gap-3 mb-3">
		{avatarUrl && <img src={avatarUrl} alt="" class="size-10 rounded-full bg-slate-100" loading="lazy" />}
		<span class="text-sm leading-tight text-slate-800">
			<span class="text-slate-500 font-normal">{owner}/</span>
			<strong class="text-base text-slate-900 block">{repo}</strong>
		</span>
	</header>

	<div>
		<p class="text-sm text-slate-600 leading-relaxed flex-1 mb-4">{description}</p>

		<div class="flex gap-3 text-xs text-slate-500">
			<span>{stars} star{stars !== 1 ? 's' : ''}</span>
			<span>{forks} fork{forks !== 1 ? 's' : ''}</span>
		</div>
	</div>

	{langSegments.length > 0 && (
		<div class="-mx-4 mt-4 -mb-4 h-1.5 overflow-hidden bg-slate-200 flex" aria-hidden="true">
			{langSegments.map((seg) => (
				<span
					class="h-full"
					style={`width:${seg.pct}%;background:${seg.color}`}
				/>
			))}
		</div>
	)}
</a>

