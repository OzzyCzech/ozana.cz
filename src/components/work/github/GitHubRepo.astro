---
import { fetchRepo } from '../../../lib/github';
import type { GitHubRepo as GitHubRepoType } from '../../../lib/github';

export interface Props {
	url: string;
}

// GitHub linguist language colors
const LANGUAGE_COLORS: Record<string, string> = {
	'JavaScript': '#f1e05a',
	'TypeScript': '#3178c6',
	'PHP':        '#4F5D95',
	'Python':     '#3572A5',
	'HTML':       '#e34c26',
	'CSS':        '#563d7c',
	'Shell':      '#89e051',
	'Go':         '#00ADD8',
	'Rust':       '#dea584',
	'Ruby':       '#701516',
	'Java':       '#b07219',
	'C':          '#555555',
	'C++':        '#f34b7d',
	'Swift':      '#F05138',
	'Kotlin':     '#A97BFF',
	'Vue':        '#41b883',
	'Svelte':     '#ff3e00',
	'Astro':      '#ff5a03',
};

const {url} = Astro.props as Props;
const repository = new URL(url).pathname.replace(/^\/|\/$/g, '');
const [owner, repo] = repository.split('/');

const data = (await fetchRepo(repository)) as GitHubRepoType;

const description = data.description || '';
const stars = data.stargazers_count || 0;
const forks = data.forks_count || 0;
const avatarUrl = data.owner?.avatar_url;

const language = data.language || '';
const languagesRaw = (data.languages && typeof data.languages === 'object') ? data.languages : null;
const languagesEntries = languagesRaw ? Object.entries(languagesRaw).filter(([, v]) => typeof v === 'number' && v > 0) : [];
const totalBytes = languagesEntries.reduce((sum, [, v]) => sum + v, 0);

type LangSeg = { name: string; pct: number; color: string; bytes: number };
let langSegments: LangSeg[] = [];

if (totalBytes > 0) {
	langSegments = languagesEntries
		.sort((a, b) => b[1] - a[1])
		.map(([name, bytes]) => ({
			name,
			bytes,
			pct: (bytes / totalBytes) * 100,
			color: LANGUAGE_COLORS[name] || '#94a3b8',
		}));

	const MAX_SEGMENTS = 4;
	if (langSegments.length > MAX_SEGMENTS) {
		const head = langSegments.slice(0, MAX_SEGMENTS);
		const tail = langSegments.slice(MAX_SEGMENTS);
		const otherBytes = tail.reduce((s, x) => s + x.bytes, 0);
		const otherPct = tail.reduce((s, x) => s + x.pct, 0);
		langSegments = [
			...head,
			{ name: 'Other', bytes: otherBytes, pct: otherPct, color: '#94a3b8' },
		];
	}
} else if (language) {
	langSegments = [{ name: language, bytes: 1, pct: 100, color: LANGUAGE_COLORS[language] || '#94a3b8' }];
}
---

<article>
	{langSegments.length > 0 && (
		<div class="langbar" aria-hidden="true">
			{langSegments.map((seg) => (
				<span
					class="seg"
					style={`width:${seg.pct}%;background:${seg.color}`}
					title={`${seg.name} ${Math.round(seg.pct)}%`}
				/>
			))}
		</div>
	)}
	<header>
		<a href={url} target="_blank" rel="noopener" class="repo-link">
			{avatarUrl && <img src={avatarUrl} alt="" class="avatar" loading="lazy" />}
			<span class="repo-name">
				<span class="owner">{owner}/</span>
				<strong>{repo}</strong>
			</span>
		</a>
	</header>

	<p class="description">{description}</p>

	<footer>
		<div class="stats">
			{stars > 0 && <span>{stars} star{stars !== 1 ? 's' : ''}</span>}
			{forks > 0 && <span>{forks} fork{forks !== 1 ? 's' : ''}</span>}
		</div>
		<a href={url} target="_blank" rel="noopener" class="btn btn-xs">View code</a>
	</footer>
</article>

<style>
	@reference "tailwindcss";

	article {
		@apply overflow-hidden flex flex-col;
		@apply rounded-xl bg-white;
		@apply border border-slate-200;
		@apply transition-shadow hover:shadow-md;
		@apply has-[:focus-visible]:outline has-[:focus-visible]:outline-offset-1;
		@apply p-4;
	}

	.langbar {
		@apply -m-4 mb-3 h-1.5 overflow-hidden bg-slate-200;
		@apply flex;
	}

	.seg {
		@apply h-full;
	}

	header {
		@apply mb-3;
	}

	.repo-link {
		@apply flex items-center gap-3 hover:no-underline text-slate-800;
	}

	.avatar {
		@apply size-10 rounded-full bg-slate-100;
	}

	.repo-name {
		@apply text-sm leading-tight;
	}

	.owner {
		@apply text-slate-500 font-normal;
	}

	strong {
		@apply text-base text-slate-900 block;
	}

	.description {
		@apply text-sm text-slate-600 leading-relaxed flex-1 mb-4;
	}

	.stats {
		@apply flex gap-3 text-xs text-slate-500 mb-3;
	}
</style>
